# Copy to /etc/knausen-signal/env (mode 600, root-owned) and fill in the
# secrets. systemd loads it via EnvironmentFile=.

# --- Router (LAN-local) ---
# The collector talks to the router over SSH → `JsonClient` (against the
# router's local Unix socket). One-time router setup: install the pubkey
# below in /data/user/ssh/authorized_keys on the router — see README.
KNAUSEN_MODEM_HOST=192.168.1.1
KNAUSEN_MODEM_SSH_USER=admin
KNAUSEN_MODEM_SSH_KEY=/var/lib/knausen-signal/.ssh/id_ed25519_router

# --- Sampling intervals (seconds) ---
KNAUSEN_MODEM_INTERVAL_SEC=900
KNAUSEN_PROBE_INTERVAL_SEC=900
KNAUSEN_PUSH_INTERVAL_SEC=60

# --- Probe targets ---
KNAUSEN_PING_TARGETS=1.1.1.1,8.8.8.8,9.9.9.9

# --- Segmented-ping checkpoints (per-segment latency) ---
# Format: name=host,name=host,... Pinged independently each probe cycle.
# Defaults assume the Lyse-via-Oslo path; re-set if your carrier rotates
# the carrier_edge IP (visible as hop 4 in `sudo mtr -rwc 10 1.1.1.1`).
KNAUSEN_PROBE_CHECKPOINTS=gateway=192.168.1.1,carrier_edge=10.4.208.17,peering=nix1-gw.world-online.no,destination=1.1.1.1

# --- Triggered mtr snapshots (per-hop forensic snapshot when p95 spikes) ---
# enabled=false disables the feature entirely (no mtr subprocess, no shipping).
KNAUSEN_MTR_ENABLED=true
KNAUSEN_MTR_TARGET=8.8.8.8
KNAUSEN_MTR_TRIGGER_P95_MS=500
KNAUSEN_MTR_COOLDOWN_SEC=600
KNAUSEN_MTR_PROBE_COUNT=30

# --- Storage ---
KNAUSEN_DB_PATH=/var/lib/knausen-signal/data.sqlite
KNAUSEN_LOG_LEVEL=INFO

# --- Remote write (self-hosted VictoriaMetrics) ---
# The URL is the VM remote_write endpoint. User/password are optional —
# leave blank for unauthenticated local VM, fill in only if the remote
# is behind basic auth.
KNAUSEN_PROMETHEUS_URL=http://localhost:8428/api/v1/write
KNAUSEN_PROMETHEUS_USER=
KNAUSEN_PROMETHEUS_PASSWORD=
