# Copy to /etc/knausen-signal/env (mode 600, root-owned) and fill in the
# secrets. systemd loads it via EnvironmentFile=.

# --- Router (LAN-local) ---
KNAUSEN_MODEM_HOST=192.168.1.1
KNAUSEN_MODEM_USER=admin
KNAUSEN_MODEM_PASSWORD=changeme

# --- Sampling intervals (seconds) ---
KNAUSEN_MODEM_INTERVAL_SEC=900
KNAUSEN_PROBE_INTERVAL_SEC=900
KNAUSEN_PUSH_INTERVAL_SEC=60

# --- Probe targets ---
KNAUSEN_PING_TARGETS=1.1.1.1,8.8.8.8,9.9.9.9

# --- Storage ---
KNAUSEN_DB_PATH=/var/lib/knausen-signal/data.sqlite
KNAUSEN_LOG_LEVEL=INFO

# --- Grafana Cloud (Prometheus remote_write) ---
# Find these under your Grafana Cloud stack > Prometheus > "Send Metrics".
KNAUSEN_PROMETHEUS_URL=https://prometheus-prod-XX-prod-eu-west-2.grafana.net/api/prom/push
KNAUSEN_PROMETHEUS_USER=
KNAUSEN_PROMETHEUS_PASSWORD=
