{
  "title": "Knausen — felt network quality",
  "rows": [
    {
      "title": "Status (right now)",
      "panels": [
        {
          "title": "Probe OK (1 = last cycle succeeded)",
          "width": 4,
          "expr": ["knausen_probe_ok", "vector(0)", "vector(1)"],
          "alias": ["probe_ok", "0", "1"]
        },
        {
          "title": "Modem connected (1 = LTE attach)",
          "width": 4,
          "expr": ["knausen_modem_connected", "vector(0)", "vector(1)"],
          "alias": ["connected", "0", "1"]
        },
        {
          "title": "Collector heartbeat (1 = alive)",
          "width": 4,
          "expr": ["knausen_collector_heartbeat", "vector(0)", "vector(1)"],
          "alias": ["heartbeat", "0", "1"]
        }
      ]
    },
    {
      "title": "Data usage — current billing cycle",
      "panels": [
        {
          "title": "Total (GB) — matches the router home page's Data Usage figure",
          "width": 6,
          "expr": [
            "knausen_modem_data_usage_total_bytes / 1024 / 1024 / 1024"
          ],
          "alias": ["total_gb"],
          "showLegend": false
        },
        {
          "title": "Sent vs received (GB)",
          "width": 6,
          "expr": [
            "knausen_modem_data_usage_tx_bytes / 1024 / 1024 / 1024",
            "knausen_modem_data_usage_rx_bytes / 1024 / 1024 / 1024"
          ],
          "alias": ["tx_gb", "rx_gb"],
          "showLegend": true
        }
      ]
    },
    {
      "title": "Latency — ping RTT",
      "panels": [
        {
          "title": "Ping RTT — p50 (red) and p95 (blue), ms",
          "width": 12,
          "expr": [
            "knausen_probe_ping_rtt_ms_p50",
            "knausen_probe_ping_rtt_ms_p95"
          ],
          "showLegend": false
        }
      ]
    },
    {
      "title": "Latency — per-segment RTT (where the delay enters the path)",
      "panels": [
        {
          "title": "Checkpoint RTT p50 by segment — gateway → carrier_edge → peering → destination",
          "width": 12,
          "expr": ["knausen_probe_checkpoint_rtt_ms_p50"],
          "showLegend": true
        },
        {
          "title": "Checkpoint RTT p95 by segment (tail per hop)",
          "width": 12,
          "expr": ["knausen_probe_checkpoint_rtt_ms_p95"],
          "showLegend": true
        }
      ]
    },
    {
      "title": "Latency — packet loss",
      "panels": [
        {
          "title": "Packet loss %  (Y-axis pinned 0..100)",
          "width": 12,
          "expr": ["knausen_probe_ping_loss_pct", "vector(0)", "vector(100)"],
          "alias": ["loss_pct", "0", "100"],
          "showLegend": false
        }
      ]
    },
    {
      "title": "Web responsiveness — DNS",
      "panels": [
        {
          "title": "DNS lookup time, ms",
          "width": 12,
          "expr": ["knausen_probe_dns_lookup_ms"],
          "showLegend": false
        }
      ]
    },
    {
      "title": "Web responsiveness — HTTPS HEAD",
      "panels": [
        {
          "title": "HTTPS HEAD round-trip, ms",
          "width": 12,
          "expr": ["knausen_probe_https_head_ms"],
          "showLegend": false
        }
      ]
    },
    {
      "title": "Path snapshots (triggered mtr)",
      "panels": [
        {
          "title": "Carrier-edge (hop 4) worst-case RTT — diagnostic line for queue buildup at the Lyse edge",
          "width": 12,
          "expr": ["knausen_mtr_hop_rtt_ms_worst{hop_num=\"4\"}"],
          "showLegend": false
        },
        {
          "title": "All hops — worst-case RTT (latest snapshot tells you which hop owns the tail)",
          "width": 12,
          "expr": ["knausen_mtr_hop_rtt_ms_worst"],
          "showLegend": true
        }
      ]
    },
    {
      "title": "LTE radio — signal levels",
      "panels": [
        {
          "title": "RSRP (red, dBm), RSRQ (blue, dB), RSSI (green, dBm). All negative; closer to 0 is stronger.",
          "width": 12,
          "expr": [
            "knausen_modem_rsrp_dbm",
            "knausen_modem_rsrq_db",
            "knausen_modem_rssi_dbm"
          ],
          "showLegend": false
        }
      ]
    },
    {
      "title": "LTE radio — SINR",
      "panels": [
        {
          "title": "SINR (dB) — signal-to-interference-plus-noise; higher is cleaner. Same x-axis as the panel above for visual correlation.",
          "width": 12,
          "expr": ["knausen_modem_snr_db"],
          "showLegend": false
        }
      ]
    }
  ]
}
