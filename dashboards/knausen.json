{
  "title": "Knausen — felt network quality",
  "rows": [
    {
      "title": "Status (right now)",
      "panels": [
        {
          "title": "Probe OK (1 = last cycle succeeded)",
          "width": 4,
          "expr": ["knausen_probe_ok", "vector(0)", "vector(1)"],
          "alias": ["probe_ok", "0", "1"]
        },
        {
          "title": "Modem connected (1 = LTE attach)",
          "width": 4,
          "expr": ["knausen_modem_connected", "vector(0)", "vector(1)"],
          "alias": ["connected", "0", "1"]
        },
        {
          "title": "Collector heartbeat (1 = alive)",
          "width": 4,
          "expr": ["knausen_collector_heartbeat", "vector(0)", "vector(1)"],
          "alias": ["heartbeat", "0", "1"]
        }
      ]
    },
    {
      "title": "Latency — ping RTT",
      "panels": [
        {
          "title": "Ping RTT — p50 (red) and p95 (blue), ms",
          "width": 12,
          "expr": [
            "knausen_probe_ping_rtt_ms_p50",
            "knausen_probe_ping_rtt_ms_p95"
          ],
          "showLegend": false
        }
      ]
    },
    {
      "title": "Latency — packet loss",
      "panels": [
        {
          "title": "Packet loss %  (Y-axis pinned 0..100)",
          "width": 12,
          "expr": ["knausen_probe_ping_loss_pct", "vector(0)", "vector(100)"],
          "alias": ["loss_pct", "0", "100"],
          "showLegend": false
        }
      ]
    },
    {
      "title": "Web responsiveness — DNS",
      "panels": [
        {
          "title": "DNS lookup time, ms",
          "width": 12,
          "expr": ["knausen_probe_dns_lookup_ms"],
          "showLegend": false
        }
      ]
    },
    {
      "title": "Web responsiveness — HTTPS HEAD",
      "panels": [
        {
          "title": "HTTPS HEAD round-trip, ms",
          "width": 12,
          "expr": ["knausen_probe_https_head_ms"],
          "showLegend": false
        }
      ]
    },
    {
      "title": "LTE radio — signal levels",
      "panels": [
        {
          "title": "RSRP (red, dBm), RSRQ (blue, dB), RSSI (green, dBm). All negative; closer to 0 is stronger.",
          "width": 12,
          "expr": [
            "knausen_modem_rsrp_dbm",
            "knausen_modem_rsrq_db",
            "knausen_modem_rssi_dbm"
          ],
          "showLegend": false
        }
      ]
    },
    {
      "title": "LTE radio — SINR",
      "panels": [
        {
          "title": "SINR (dB) — signal-to-interference-plus-noise; higher is cleaner. Same x-axis as the panel above for visual correlation.",
          "width": 12,
          "expr": ["knausen_modem_snr_db"],
          "showLegend": false
        }
      ]
    }
  ]
}
